    <script>
        // Core Webpack-less Vanilla JS to power UI state seamlessly

        // 1. Sticky & Tint-changing Navbar on Scroll
        const mainNav = document.getElementById('mainNav');
        const navLogoText = document.getElementById('navLogoText');
        
        window.addEventListener('scroll', () => {
            if (window.scrollY > 80) {
                mainNav.classList.remove('bg-transparent');
                mainNav.classList.add('bg-white', 'shadow-md', 'h-16');
                mainNav.classList.remove('h-20');
                navLogoText.classList.remove('text-white');
                navLogoText.classList.add('text-slate-800');
                
                // Adjust desktop menu color links
                const links = mainNav.querySelectorAll('a:not(.bg-ocean-500)');
                links.forEach(link => {
                    link.classList.remove('text-white', 'hover:text-ocean-200');
                    link.classList.add('text-slate-600', 'hover:text-ocean-600');
                });
            } else {
                mainNav.classList.add('bg-transparent');
                mainNav.classList.remove('bg-white', 'shadow-md', 'h-16');
                mainNav.classList.add('h-20');
                navLogoText.classList.add('text-white');
                navLogoText.classList.remove('text-slate-800');
                
                const links = mainNav.querySelectorAll('a:not(.bg-ocean-500)');
                links.forEach(link => {
                    link.classList.add('text-white', 'hover:text-ocean-200');
                    link.classList.remove('text-slate-600', 'hover:text-ocean-600');
                });
            }
        });

        // 2. Mobile Drawer Toggle
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const mobileDrawer = document.getElementById('mobileDrawer');
        
        mobileMenuBtn.addEventListener('click', () => {
            mobileDrawer.classList.toggle('hidden');
        });

        // Smooth scroll helper
        function scrollToId(id) {
            const el = document.getElementById(id);
            if (el) {
                el.scrollIntoView({ behavior: 'smooth' });
                mobileDrawer.classList.add('hidden'); // Close mobile drawer if open
            }
        }

        // 3. Custom Toast Notification System
        function showToast(message, isInfo = true) {
            const toastBox = document.getElementById('toastBox');
            const toastMsg = document.getElementById('toastMsg');
            const toastIcon = document.getElementById('toastIcon');
            
            toastMsg.innerText = message;
            if (isInfo) {
                toastIcon.innerHTML = `<i class="fa-solid fa-circle-check"></i>`;
                toastIcon.className = "text-emerald-400 text-xl";
            } else {
                toastIcon.innerHTML = `<i class="fa-solid fa-triangle-exclamation"></i>`;
                toastIcon.className = "text-sunset-500 text-xl";
            }
            
            toastBox.classList.remove('translate-y-20', 'opacity-0');
            toastBox.classList.add('translate-y-0', 'opacity-100');
            
            setTimeout(() => {
                toastBox.classList.remove('translate-y-0', 'opacity-100');
                toastBox.classList.add('translate-y-20', 'opacity-0');
            }, 3000);
        }

        // 4. Attractions Filter logic
        function filterSpots(category) {
            const cards = document.querySelectorAll('.spot-card');
            const btns = document.querySelectorAll('.spot-filter-btn');
            
            // Toggle active style on buttons
            btns.forEach(btn => {
                btn.className = "spot-filter-btn px-4 py-2 rounded-full text-xs sm:text-sm font-semibold bg-white text-slate-600 hover:bg-slate-100 transition-all shadow-sm";
            });
            event.currentTarget.className = "spot-filter-btn px-4 py-2 rounded-full text-xs sm:text-sm font-semibold bg-ocean-500 text-white shadow-md transition-all";

            cards.forEach(card => {
                if (category === 'all' || card.getAttribute('data-category') === category) {
                    card.classList.remove('hidden');
                    card.classList.add('block');
                } else {
                    card.classList.remove('block');
                    card.classList.add('hidden');
                }
            });
        }

        // 5. Day-by-Day Itinerary Tab Switcher
        function switchDay(dayNum) {
            const days = [1, 2, 3];
            days.forEach(num => {
                const btn = document.getElementById(`day${num}Btn`);
                const content = document.getElementById(`day${num}Content`);
                
                if (num === dayNum) {
                    btn.className = "day-tab px-6 py-3 rounded-2xl text-sm font-bold bg-ocean-500 text-white shadow-md transition-all";
                    content.classList.remove('hidden');
                } else {
                    btn.className = "day-tab px-6 py-3 rounded-2xl text-sm font-bold bg-slate-100 text-slate-600 hover:bg-slate-200 transition-all";
                    content.classList.add('hidden');
                }
            });
        }

        // 6. Interactive Custom Itinerary Builder
        let savedItinerary = [];
        function toggleItinerary(itemName) {
            const index = savedItinerary.indexOf(itemName);
            if (index > -1) {
                savedItinerary.splice(index, 1);
                showToast(`已從我的清單移除：${itemName}`, false);
            } else {
                savedItinerary.push(itemName);
                showToast(`已加進我的收藏清單！⭐️`);
            }
            renderSavedItinerary();
        }

        function clearCustomItinerary() {
            savedItinerary = [];
            renderSavedItinerary();
            showToast('清單已全部清空。', false);
        }

        function renderSavedItinerary() {
            const listContainer = document.getElementById('customItineraryList');
            if (savedItinerary.length === 0) {
                listContainer.innerHTML = `<p class="text-center py-4">目前尚未加入行程項目。點選上方「三日行程」右側的星號 <i class="fa-regular fa-star"></i> 來打包收藏吧！</p>`;
                return;
            }

            let html = '<ul class="space-y-2 bg-slate-950 p-4 rounded-2xl border border-slate-800">';
            savedItinerary.forEach((item, index) => {
                html += `
                    <li class="flex items-center justify-between py-1 border-b border-slate-900 last:border-0 text-white text-[11px]">
                        <span><i class="fa-solid fa-circle-check text-emerald-400 mr-1.5"></i> ${item}</span>
                        <button onclick="toggleItinerary('${item}')" class="text-slate-500 hover:text-red-400"><i class="fa-solid fa-trash-can"></i></button>
                    </li>
                `;
            });
            html += `
                <div class="mt-4 pt-3 border-t border-slate-800 text-center">
                    <button onclick="shareItinerary()" class="w-full bg-ocean-500 hover:bg-ocean-600 text-white font-bold py-1.5 px-3 rounded-lg text-[10px] transition-colors">
                        <i class="fa-solid fa-share-nodes mr-1"></i> 複製我的特製行程
                    </button>
                </div>
            `;
            html += '</ul>';
            listContainer.innerHTML = html;
        }

        function shareItinerary() {
            const textToCopy = `我的小琉球客製化夢幻行程：\n` + savedItinerary.map((it, idx) => `[第 ${idx+1} 步] ${it}`).join('\n') + `\n\n— 本清單產生自「藍海織夢 ｜ 小琉球極致蔚藍指南」`;
            
            // Fallback for copy action inside iFrames
            const textarea = document.createElement("textarea");
            textarea.value = textToCopy;
            document.body.appendChild(textarea);
            textarea.select();
            try {
                document.execCommand('copy');
                showToast("🎉 行程內容已成功複製到剪貼簿，快與旅伴分享吧！");
            } catch (err) {
                showToast("複製失敗，請手動選取複製", false);
            }
            document.body.removeChild(textarea);
        }

        // 7. Interactive Map Display Helper
        function showMapPin(title, desc) {
            const titleEl = document.getElementById('mapInfoText');
            const panelEl = document.getElementById('mapDetailPanel');
            
            titleEl.innerHTML = `<span class="bg-ocean-500/10 px-3 py-1 rounded-full text-white border border-ocean-500/30 font-bold">${title}</span>`;
            panelEl.innerHTML = `<span class="text-white font-medium">${desc}</span>`;
            
            showToast(`正在環遊島嶼：${title}`);
        }

        // 8. Budget Calculator State & Calculations
        let calcPeople = 2;
        let calcDays = 3;

        function updatePeople(change) {
            calcPeople += change;
            if (calcPeople < 1) calcPeople = 1;
            document.getElementById('calcPeople').innerText = calcPeople;
            calcTotal();
        }

        function setCalcDays(days) {
            calcDays = days;
            const buttons = document.querySelectorAll('.calc-day-btn');
            buttons.forEach(btn => {
                btn.className = "calc-day-btn px-4 py-2 rounded-xl text-xs font-bold bg-slate-800 text-slate-300";
            });
            document.getElementById(`btnCD${days}`).className = "calc-day-btn px-4 py-2 rounded-xl text-xs font-bold bg-ocean-500 text-white";
            calcTotal();
        }

        function calcTotal() {
            // Base cost parameters
            let stayCostPerNight = 3200; // Average double room price
            let basicFoodCostPerDay = 500; // Basic delicious food & sweet potato pancakes etc
            
            let total = 0;
            
            // 1. Ferry
            if (document.getElementById('itemFerry').checked) {
                total += 410 * calcPeople;
            }
            // 2. Scooter (one scooter per 2 people)
            if (document.getElementById('itemScooter').checked) {
                let scooterCount = Math.ceil(calcPeople / 2);
                total += scooterCount * 400 * calcDays;
            }
            // 3. Water Activity
            if (document.getElementById('itemWater').checked) {
                total += 1200 * calcPeople;
            }

            // 4. Basic Living (Stay is days-1 except if day is 1)
            let nights = calcDays - 1;
            if (nights < 0) nights = 0;
            
            // Accommodation cost (assume we need enough rooms for groups of 2)
            let roomCount = Math.ceil(calcPeople / 2);
            total += roomCount * stayCostPerNight * nights;

            // Food cost
            total += basicFoodCostPerDay * calcDays * calcPeople;

            // Format total
            document.getElementById('totalPrice').innerText = `NT$ ${total.toLocaleString()}`;
        }

        // 9. Checklist Packing Items
        const packingItems = [
            { text: "防曬乳 / 海洋友善防曬", category: "essential" },
            { text: "個人泳衣 / 泳褲 / 水母衣", category: "essential" },
            { text: "防水袋 / 手機防水袋", category: "gear" },
            { text: "舒適防滑拖鞋 / 涼鞋", category: "essential" },
            { text: "身分證 / 健保卡 / 駕照 (必備！)", category: "essential" },
            { text: "暈船藥 (搭船前30分鐘吃)", category: "gear" },
            { text: "遮陽帽 / 墨鏡", category: "gear" },
            { text: "輕量環保水壺 (小島倡導減塑)", category: "essential" }
        ];

        function renderChecklist() {
            const container = document.getElementById('checklistContainer');
            container.innerHTML = "";
            
            packingItems.forEach((item, index) => {
                const itemDiv = document.createElement('div');
                itemDiv.className = "flex items-center space-x-3 bg-slate-800/40 p-3 rounded-xl hover:bg-slate-800 transition-colors cursor-pointer";
                itemDiv.innerHTML = `
                    <input type="checkbox" id="pack-${index}" class="w-4 h-4 text-emerald-500 bg-slate-900 border-slate-700 rounded focus:ring-emerald-500">
                    <label for="pack-${index}" class="text-xs text-slate-300 font-medium cursor-pointer select-none">${item.text}</label>
                `;
                container.appendChild(itemDiv);
            });
        }

        // Initialize state on load
        window.onload = function() {
            calcTotal();
            renderChecklist();
            
            // Welcome greeting
            setTimeout(() => {
                showToast("🌊 準備好與綠蠵龜共游了嗎？快來規劃吧！");
            }, 1000);
        };
    </script>
</body>
</html>
